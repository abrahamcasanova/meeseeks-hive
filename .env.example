DATABASE_URL=postgresql://meeseeks:meeseeks@localhost:5432/meeseeks_hive

# ── LLM Provider ──────────────────────────────────────────────────
# Options: claude | bedrock | openai | ollama
LLM_PROVIDER=bedrock

# ── Anthropic Direct API ───────────────────────────────────────────
# When LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── AWS Bedrock ────────────────────────────────────────────────────
# When LLM_PROVIDER=bedrock
# Uses AWS credential chain: ~/.aws/credentials, env vars, IAM role
BEDROCK_REGION=us-east-2
BEDROCK_CLAUDE_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── OpenAI ─────────────────────────────────────────────────────────
# When LLM_PROVIDER=openai (can use for both LLM and embeddings)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ── Ollama Local ───────────────────────────────────────────────────
# When LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Embedding Provider ─────────────────────────────────────────────
# Options: openai | bedrock
# Default: bedrock (uses Amazon Titan Embeddings v2)
# If using LLM_PROVIDER=openai, you can reuse the same API key for embeddings
EMBEDDING_PROVIDER=bedrock

# ── Server Config ──────────────────────────────────────────────────
PORT=3001
WS_PORT=3002
NODE_ENV=development
